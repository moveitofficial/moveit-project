{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true
  },
  "include": [
    "${configDir}/next-env.d.ts",
    "${configDir}/**/*.ts",
    "${configDir}/**/*.tsx",
    "${configDir}/**/*.mts",
    "${configDir}/.next/types/**/*.ts",
    "${configDir}/.next/dev/types/**/*.ts"
  ],
  "exclude": ["${configDir}/node_modules"]
}
